{
  "crawler_settings": {
    "active": true,
    "update_frequency_days": 7,
    "max_results_per_search": 50
  },
  "search_sources": [
    {
      "name": "PubMed",
      "url": "https://pubmed.ncbi.nlm.nih.gov/",
      "enabled": true,
      "keywords": [
        "obesity treatment",
        "weight loss management",
        "metabolic syndrome",
        "bariatric surgery",
        "GLP-1 agonists"
      ]
    },
    {
      "name": "ClinicalTrials.gov",
      "url": "https://clinicaltrials.gov/",
      "enabled": true,
      "keywords": [
        "obesity",
        "weight management",
        "diabetes",
        "cardiovascular disease"
      ],
      "trial_phases": ["Phase 2", "Phase 3", "Phase 4"]
    },
    {
      "name": "WHO Guidelines",
      "url": "https://www.who.int/",
      "enabled": true,
      "keywords": ["obesity", "prevention", "treatment"]
    }
  ],
  "exclusion_criteria": [
    "animal studies",
    "in vitro",
    "theoretical models",
    "opinion pieces"
  ]
}